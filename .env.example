# ── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Anthropic ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Gemini ───────────────────────────────────────
GEMINI_API_KEY=

# ── OpenRouter (доступ ко всем моделям) ─────────────────
OPENROUTER_API_KEY=sk-or-...

# ── DeepSeek ────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Groq (быстрый inference) ────────────────────────────
GROQ_API_KEY=gsk_...

# ── Defaults ────────────────────────────────────────────
NEUROHUB_DEFAULT_PROVIDER=openai
NEUROHUB_DEFAULT_MODEL=gpt-4o-mini
NEUROHUB_TIMEOUT=120
NEUROHUB_MAX_RETRIES=3
